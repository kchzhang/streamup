{
  "name": "@knox.zhang/streamup",
  "version": "0.1.0-beta.0",
  "description": "Vue 3 streaming rendering component library",
  "type": "module",
  "main": "./dist/streams.cjs",
  "module": "./dist/streams.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/streams.mjs",
      "require": "./dist/streams.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build",
    "format": "prettier --write --experimental-cli src/",
    "prepublishOnly": "pnpm run build",
    "publish:beta": "pnpm run build && npm publish --tag beta --access public",
    "publish:release": "pnpm run build && npm publish --access public"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "@shikijs/markdown-it": ">=1.0.0",
    "@tanstack/vue-virtual": ">=3.0.0",
    "markdown-it": ">=14.0.0",
    "shiki": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@shikijs/markdown-it": {
      "optional": true
    },
    "@tanstack/vue-virtual": {
      "optional": true
    },
    "markdown-it": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "devDependencies": {
    "@shikijs/markdown-it": "^4.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.0.2",
    "markdown-it": "^14.2.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.8.3",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-mock": "^3.0.2",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "streaming",
    "rendering",
    "markdown",
    "code-highlight",
    "sse",
    "websocket"
  ],
  "license": "MIT"
}
